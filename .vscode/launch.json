{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build & Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/world_imagine",
            "args": ["test_data/point_cloud.ply"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${env:HOME}/local/libtorch/lib:/usr/local/cuda/lib64"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build"
        }
    ]
}
